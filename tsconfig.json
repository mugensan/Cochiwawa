{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,      // ← enable decorators
    "emitDecoratorMetadata": true,       // ← needed by Nest
    "types": ["node", "jest"]            // ← include Jest globals
  },
  "include": ["src/**/*.ts"]
}
